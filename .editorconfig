# EditorConfig – https://editorconfig.org
# Apply to all SDK repos for consistent formatting

root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.md]
trim_trailing_whitespace = false

[*.{py}]
indent_size = 4

[*.{json,yml,yaml}]
indent_size = 2
